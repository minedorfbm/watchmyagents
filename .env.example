# Anthropic API key for the example Claude agent
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# WatchMyAgents API key (used to derive the AES-256-GCM encryption key)
WMA_API_KEY=wma_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: remote export endpoint (HTTPS only)
WMA_EXPORT_URL=https://ingest.watchmyagents.io/v1/logs

# Optional: local log directory
WMA_LOG_DIR=./watchmyagents-logs
