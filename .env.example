# Required — your Anthropic API key (used by wma-fetch and wma-shield to
# call the Managed Agents REST API on your behalf). WatchMyAgents never
# stores, logs, or transmits this key anywhere except api.anthropic.com.
# See SECURITY.md for details.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Optional — override the default log directory (default: ./watchmyagents-logs).
# WMA_LOG_DIR=./watchmyagents-logs

# ── Fortress cloud (optional) ────────────────────────────────────────────────
# Only needed if you ship ANONYMIZED signals to the Fortress control plane
# (wma-upload-fortress, wma-fetch --watch --upload) or pull policies into Shield
# (wma-shield --policies-source fortress). Raw payloads NEVER leave your machine
# — only counts, latencies, salted IoC hashes (Modèle C). See README.md.

# Your wma_xxx key from the Fortress dashboard → Settings → API Keys.
# WMA_API_KEY=wma_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Fortress base URL (the /functions/v1 root — each tool appends its endpoint).
# WMA_FORTRESS_BASE_URL=https://<your-project>.supabase.co/functions/v1

# Per-customer hex secret used to salt IoC hashes. MUST be stable across runs
# (a fresh random salt each run breaks cross-run IoC correlation). Generate once:
#   node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# WMA_SIGNALS_SALT=
