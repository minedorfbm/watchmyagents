# Required — your Anthropic API key (used by wma-fetch and wma-shield to
# call the Managed Agents REST API on your behalf). WatchMyAgents never
# stores, logs, or transmits this key anywhere except api.anthropic.com.
# See SECURITY.md for details.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Optional — override the default log directory (default: ./watchmyagents-logs).
# WMA_LOG_DIR=./watchmyagents-logs

# Note: future versions of WatchMyAgents will introduce a WMA_API_KEY env var
# for the Fortress cloud service (anonymized telemetry, Guardian AI policy
# suggestions). These features are not yet implemented in v0.x — the SDK is
# entirely local today. See https://github.com/minedorfbm/watchmyagents
# for the roadmap.
